# ─── Pusher Beams ─────────────────────────────────────────────────────────────
# Get these from: https://dashboard.pusher.com/beams → Your Instance → Keys
BEAMS_INSTANCE_ID=YOUR_BEAMS_INSTANCE_ID_HERE
BEAMS_SECRET_KEY=YOUR_BEAMS_SECRET_KEY_HERE

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# The URL of the frontend app (for CORS and deep_link generation)
# Change to your deployed domain in production, e.g. https://yourapp.com
CLIENT_ORIGIN=http://localhost:5173

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# The URL of this Node server — used by the frontend to call /notify/* endpoints
VITE_SERVER_URL=http://localhost:3001
